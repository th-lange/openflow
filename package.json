{
  "name": "openflow",
  "version": "1.0.0",
  "description": "OpenCode workflow orchestration plugin",
  "bin": {
    "openflow": "bin/openflow.mjs"
  },
  "files": [
    "bin/",
    "dist/",
    "opencode.json",
    "openflow.json"
  ],
  "scripts": {
    "test": "node --import tsx/esm --test src/test/**/*.test.ts",
    "build": "tsc",
    "prepare": "npm run build",
    "proto": "node --import tsx/esm src/proto/spawn-test.ts",
    "start": "node dist/mcp.js",
    "e2e": "node --import tsx/esm src/proto/e2e-test.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/th-lange/openflow.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/th-lange/openflow/issues"
  },
  "homepage": "https://github.com/th-lange/openflow#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opencode-ai/sdk": "^1.17.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
